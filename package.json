{
  "name": "luxor-academy",
  "version": "0.5.0",
  "private": true,
  "description": "LUXOR Academy — retro-futuristic gamified second-brain learning platform. Phase 0.5 substrate.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "node validators/six-slots.js",
    "validate:fixtures": "node validators/run-fixtures.js",
    "extract": "node --import tsx/esm pipelines/codebase-to-course/extract.ts",
    "build": "node scripts/build.js",
    "serve": "node scripts/serve.js",
    "test": "npm run validate:fixtures && npm run test:e2e && npm run test:a11y",
    "test:e2e": "playwright test tests/smoke.spec.ts",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:validator": "playwright test tests/validator.spec.ts",
    "test:perf": "lhci autorun --config=lighthouserc.json"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.48.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
